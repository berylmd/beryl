  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.1",
    "typescript-eslint": "^8.50.0",
    "nodemon": "^3.1.14",
    "vite": "latest",
    "vitest": "latest"
  },
  "exports": {
    ".": "./dist/index.js"
  }
}
