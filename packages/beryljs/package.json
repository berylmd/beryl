{
  "name": "@repo/beryljs",
  "type": "module",
  "module": "dist/index.js",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "declaration": true,
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "generate": "nearleyc parser.ne -o grammar.ts",
