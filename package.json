{
  "name": "red-beryl",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev-android": "turbo run @repo/beryljs#dev web#dev dev-android",
    "dev-ios": "turbo run @repo/beryljs#dev web#dev dev-ios",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:ui": "turbo run test:ui --filter=@repo/web",
    "test:codegen": "turbo run dev:codegen test:codegen --filter=@repo/web",
    "dev:codegen": "turbo run dev:codegen --filter=@repo/web"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.0.0",
    "turbo": "^2.8.12",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "electron",
      "electron-winstaller"
    ]
  }
}
